source "https://rubygems.org"

# Jekyll 核心
gem "jekyll", "~> 4.3"

# GitHub Pages 环境插件（在GH Pages上自动启用，本地需手动安装）
gem "jekyll-paginate"
gem "jekyll-sitemap"
gem "jekyll-feed"
gem "jekyll-seo-tag"

# 主题
gem "jekyll-theme-minima"

# 本地运行所需
group :jekyll_plugins do
  gem "jekyll-paginate"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

# Windows 用户如遇安装问题，取消下面注释
# gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswinx64]
